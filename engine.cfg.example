#==============================================================================
# ENGINE CONFIG
#==============================================================================
# hot-reload: press 'r' in the TUI to apply changes without restarting
# (except symbol, testnet, warmup_ticks — those need a restart)
#==============================================================================

# data source
symbol=btcusdt                  # binance trading pair
use_testnet=0                   # 1 = use binance testnet (fake data, safe for testing)
use_binance_us=0                # 1 = use binance US endpoint instead of global
poll_timeout_ms=100             # how long to wait for new data before running engine tick (ms)
reconnect_delay=5               # seconds to wait before reconnecting after disconnect

# session lifecycle
wind_down_minutes=5             # minutes before 24h boundary to stop new buys and wind down

# warmup phase
warmup_ticks=128                # minimum raw ticks before trading
min_warmup_samples=128          # wait for short window to fill (128 × poll_interval ≈ 71 min at BTC rate)

#==============================================================================
# REGRESSION GATE
#==============================================================================
# the engine uses P&L regression to shift the buy gate — if we're making money,
# buy more aggressively; if losing, tighten up. these control that feedback loop.

poll_interval=100               # ticks between slow-path runs (regression, adaptation, etc)
r2_threshold=0.30               # min R² to trust regression (0-1, higher = more conservative)
slope_scale_buy=0.50            # how much P&L slope shifts the buy price (higher = more reactive)
max_shift=0.001                 # max buy gate drift as fraction of price (0.001 = 0.1% = ~$70 at BTC $70k)

#==============================================================================
# PAPER TRADING
#==============================================================================
starting_balance=10000.00       # initial paper trading balance ($)
fee_rate=0.10                   # trading fee per side (%, 0.10 = 0.1% per trade)
risk_pct=05.00                  # fraction of balance per position (%, 15 = $1500 at $10k balance)
slippage_pct=0.05               # simulated execution slippage (%, 0 = disabled, 0.05 = 0.05% worse on entry/exit)

#==============================================================================
# EXIT CONDITIONS
#==============================================================================
# TP and SL are computed from rolling volatility (stddev) at fill time.
# these percentages are multiplied by 100 to get the stddev multiplier:
# e.g. 6.00% → 6.0x stddev. at stddev=$10, TP = entry + $60, SL = entry - $25.
# percentage fallback is used when rolling stats aren't ready yet.

take_profit_pct=3.00          # take profit (%, also used as stddev multiplier)
stop_loss_pct=1.50             # stop loss (%, also used as stddev multiplier)

#==============================================================================
# ENTRY FILTERS
#==============================================================================
# these control WHEN the strategy buys. adapted by P&L regression at runtime.
# initial values set here, then the engine loosens/tightens based on performance.

volume_multiplier=3.00          # only buy when tick volume >= this * rolling avg (filters noise)
entry_offset_pct=0.15           # buy gate offset below rolling mean (%, 0.15 = 0.15% dip required)
spacing_multiplier=2.00         # min distance between entries = stddev * this (prevents clustering)

# how far the adaptive filters can drift from initial values
offset_min=0.05                 # most aggressive offset (%, smallest dip to buy)
offset_max=0.50                 # most defensive offset (%, largest dip required)
vol_mult_min=1.50               # most aggressive volume filter (lowest multiplier)
vol_mult_max=6.00               # most defensive volume filter (highest multiplier)
filter_scale=0.50               # how fast filters adapt (higher = faster response to P&L)

#==============================================================================
# RISK MANAGEMENT
#==============================================================================
max_drawdown_pct=10.00          # halt ALL buying if total P&L drops below this % of starting balance
max_exposure_pct=50.00          # max % of balance deployed in open positions
max_positions=1                 # max simultaneous open positions (1-16)

#==============================================================================
# ENHANCED BUY SIGNAL
#==============================================================================
# stddev-scaled offset: buy_price = avg - (stddev * mult)
# scales with volatility — wider dips required in volatile markets, tighter in calm ones
# set to 0 to use percentage-based offset instead

offset_stddev_mult=1.50         # stddev multiplier for buy offset (0 = use entry_offset_pct instead)
offset_stddev_min=0.50          # adaptation lower bound (most aggressive, 0.5 stddev dip)
offset_stddev_max=4.00          # adaptation upper bound (most defensive, 4.0 stddev dip)

# multi-timeframe gate: blocks buys when the 512-tick window shows a downtrend
# uses relative slope (slope/price), so the same value works on any asset at any price
# negative = allow mild drops, 0 = disabled
min_long_slope=-0.00005         # block when price dropping faster than 0.005%/tick

#==============================================================================
# TRAILING TAKE-PROFIT
#==============================================================================
# when price runs past the original TP in a strong trend, the TP ratchets up
# to trail the price. captures extended runs instead of exiting at the first target.
# hold_score = (slope/stddev) * R² — requires the trend to be BOTH strong AND consistent.
# set tp_hold_score to 0 to disable (use fixed TP).

tp_hold_score=0.15              # min score to hold past TP (0 = disabled, 0.1-0.3 typical)
tp_trail_mult=1.00              # trailing TP distance in stddevs below price (0.5-2.0 recommended)
sl_trail_mult=2.00              # trailing SL distance in stddevs below price (wider than TP)

#==============================================================================
# TIME-BASED EXIT
#==============================================================================
# close positions held too long with insufficient gain. frees capital trapped
# in positions where TP became unreachable (e.g. volatility dropped after entry).
# only closes if gain is below min_hold_gain_pct — profitable positions are kept.

max_hold_ticks=50000            # close after this many ticks (~4-5 hours at 3 ticks/sec)
min_hold_gain_pct=0.10          # only time-exit if gain < this % (0.10 = 0.1%)

#==============================================================================
# REGIME DETECTION
#==============================================================================
# classifies market as RANGING (mean reversion), TRENDING (momentum), or VOLATILE (pause)
# uses rolling price slope, R², and stddev to determine regime
# hysteresis prevents rapid switching between strategies

regime_slope_threshold=0.00002  # relative slope for TRENDING detection (≈$180 move over 128 ticks at BTC $70k)
regime_r2_threshold=70.00       # min R² consistency for TRENDING (%, 70 = 0.70)
regime_volatile_stddev=0.0005   # stddev/price ratio for VOLATILE detection (legacy, kept for compat)
regime_vol_spike_ratio=2.0      # variance spike: short/long variance > this = volatile (self-adapting)
regime_hysteresis=5             # slow-path cycles before regime switch (5 = ~2.5 min at BTC rate)

#==============================================================================
# MOMENTUM STRATEGY
#==============================================================================
# buys breakouts ABOVE the rolling average (opposite of mean reversion)
# activates when regime detector identifies TRENDING market

momentum_breakout_mult=1.50     # buy when price > avg + stddev * this (1.5 = 1.5σ above avg)
momentum_tp_mult=3.00           # TP distance in stddevs (wider than MR to let trends run)
momentum_sl_mult=1.00           # SL distance in stddevs (tighter than MR, cut losers fast)

#==============================================================================
# TUI
#==============================================================================
tui_enabled=1                   # 0 = headless mode (for VPS/tmux), 1 = terminal dashboard
tui_render_interval=10          # render every N ticks (higher = less terminal thrash)
log_file=engine.log             # stderr redirect when tui_enabled=0 (append mode, tail -f friendly)

#==============================================================================
# LIVE TRADING (experimental, untested)
#==============================================================================
# requires secrets.cfg with api_key and api_secret (gitignored, never commit)
# US users: get keys from binance.us (Account Settings > API Management) and set use_binance_us=1
# global users: get keys from binance.com, or testnet from testnet.binance.vision
# WARNING: use at your own risk — not validated on a live exchange

use_real_money=0                # 0 = paper trading (default safe), 1 = real orders via REST API
# use_binance_us=1              # uncomment for Binance US (required for US-based users)
